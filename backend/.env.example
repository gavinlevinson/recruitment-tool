# ─────────────────────────────────────────────────────────────
# RecruitIQ — Environment Variables
# Copy this file to .env and fill in your values
# In production, set these directly in Railway dashboard
# ─────────────────────────────────────────────────────────────

# Database (auto-set by Railway when you add PostgreSQL service)
# Locally this is not needed — defaults to SQLite
DATABASE_URL=postgresql://...

# JWT Secret — use a long random string in production
# Generate one: python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your-secret-key-here

# Frontend URL — your Vercel deployment URL (for CORS)
# Example: https://recruitiq.vercel.app
FRONTEND_URL=

# File uploads directory (Railway volume mount path)
# Leave empty locally — defaults to ./uploads
UPLOADS_DIR=

# Anthropic API Key — for AI coaching features
# Get yours at: https://console.anthropic.com
ANTHROPIC_API_KEY=

# Apollo.io API Key — for Networking page contact discovery
# Get yours at: https://app.apollo.io/#/settings/integrations/api
APOLLO_API_KEY=

# Hunter.io API Key — free email domain lookup
# Get yours at: https://hunter.io/api → Settings → API
HUNTER_API_KEY=

# Apify API Key — for LinkedIn job scraping
# Get yours at: https://apify.com/ → Settings → Integrations → API tokens
APIFY_API_KEY=
