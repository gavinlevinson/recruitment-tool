# ─────────────────────────────────────────────────────────────
# RecruitIQ — Environment Variables
# Copy this file to .env and fill in your API keys
# ─────────────────────────────────────────────────────────────

# Apollo.io API Key (for Networking page contact search)
# Get yours at: https://app.apollo.io/#/settings/integrations/api
APOLLO_API_KEY=

# Apify API Key (for LinkedIn job scraping on Job Discovery page)
# Get yours at: https://apify.com/ → Settings → Integrations → API tokens
APIFY_API_KEY=
